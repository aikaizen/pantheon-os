{
  "id": "promptengines",
  "name": "PromptEngines",
  "type": "reference-deployment",
  "description": "First internal deployment of Pantheon OS.",
  "primary_surfaces": [
    "company-dashboard",
    "operating-terminal"
  ],
  "runtime": {
    "local_first": true,
    "dual_harness": true,
    "portal_enabled": true,
    "observation_first": true
  },
  "modes": [
    "observe",
    "message",
    "control"
  ],
  "registries": {
    "runtimes": "registry/runtimes.yaml",
    "controllers": "registry/controllers.yaml",
    "channels": "registry/channels.yaml",
    "bindings": "registry/bindings.yaml"
  },
  "pilot_scope": {
    "tier_1": [
      "promptengines-web",
      "lab-notes",
      "kaizen",
      "consulting"
    ],
    "tier_2": [
      "norbu",
      "bible",
      "storybook-studio"
    ],
    "tier_3": [
      "flow",
      "video-terminal",
      "flow-education",
      "vajra-upaya"
    ]
  },
  "notes": "PromptEngines uses Pantheon OS as its own company operating system while Pantheon OS is also being shaped as a reusable system for other companies. Existing channels and runtimes should be connected before greenfield provisioning is assumed.",
  "default_runtime_system": "hermes",
  "default_branding_mode": "white_labeled",
  "supported_runtime_systems": [
    "hermes",
    "openclaw",
    "nanoclaw",
    "pantheon"
  ],
  "provisioning_templates": [
    {
      "id": "deploy-with-pantheon",
      "runtime_system": "hermes",
      "branding_mode": "white_labeled",
      "packaging": "docker",
      "support_level": "first_party"
    },
    {
      "id": "attach-existing-runtime",
      "runtime_systems": [
        "hermes",
        "openclaw",
        "nanoclaw",
        "pantheon"
      ],
      "branding_mode": "native_or_white_labeled",
      "packaging": "docker",
      "support_level": "adapter"
    }
  ]
}
