{
  "id": "promptengines",
  "name": "PromptEngines",
  "type": "reference-deployment",
  "description": "First internal deployment of Pantheon OS.",
  "primary_surfaces": [
    "company-dashboard",
    "operating-terminal"
  ],
  "runtime": {
    "local_first": true,
    "dual_harness": true,
    "portal_enabled": true,
    "observation_first": true,
    "runtime_model": {
      "host_overseer_required": true,
      "hermes_instance_deployment_unit": "single-docker-container",
      "max_agents_per_hermes": 4,
      "topology_rule": "Each Hermes instance is deployed in a single Docker container and supervised by a host-level overseer agent."
    },
    "current_topology": {
      "host_count": 1,
      "overseer_count": 1,
      "hermes_instance_count": 1,
      "active_agents": 2,
      "open_agent_slots": 2,
      "active_runtime_ids": [
        "promptengines-hermes-primary"
      ],
      "active_agent_ids": [
        "dzambhala",
        "hermetic-demiurge"
      ]
    }
  },
  "modes": [
    "observe",
    "message",
    "control"
  ],
  "registries": {
    "runtimes": "registry/runtimes.yaml",
    "controllers": "registry/controllers.yaml",
    "channels": "registry/channels.yaml",
    "bindings": "registry/bindings.yaml"
  },
  "pilot_scope": {
    "tier_1": [
      "promptengines-web",
      "lab-notes",
      "kaizen",
      "consulting"
    ],
    "tier_2": [
      "norbu",
      "bible",
      "storybook-studio"
    ],
    "tier_3": [
      "flow",
      "video-terminal",
      "flow-education",
      "vajra-upaya"
    ]
  },
  "notes": "PromptEngines uses Pantheon OS as its own company operating system while Pantheon OS is also being shaped as a reusable system for other companies. Existing channels and runtimes should be connected before greenfield provisioning is assumed."
}
